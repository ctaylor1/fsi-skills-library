  "sections": [
    {
      "section_id": "document-control",
      "heading": "Document Control",
      "body": {
        "policy_id": "POL-AML-001",
        "title": "Customer Identification Program (CIP) Policy",
        "policy_type": "policy",
        "tier": "tier-1",
        "version": "2.4",
        "prior_version": "2.3",
        "change_type": "minor",
        "owner": "BSA Officer",
        "classification": "Confidential",
        "proposed_effective_date": "2026-09-01",
        "next_review_date": "2027-09-01"
      }
    },
    {
      "section_id": "purpose",
      "heading": "Purpose",
      "clauses": [
        {
          "clause_id": "C-1",
          "heading": "Purpose",
          "text": "This policy establishes the Customer Identification Program used to verify the identity of customers opening accounts.",
          "normative": false
        }
      ]
    },
    {
      "section_id": "scope",
      "heading": "Scope",
      "clauses": [
        {
          "clause_id": "C-2",
          "heading": "Scope",
          "text": "This policy applies to all lines of business that open accounts for customers in the United States.",
          "normative": false
        }
      ]
    },
    {
      "section_id": "policy-statements",
      "heading": "Policy Statements",
      "clauses": [
        {
          "clause_id": "C-3",
          "heading": "Identifying information",
          "text": "Before opening an account, the bank shall obtain the customer's name, date of birth, residential or business address, and identification number.",
          "normative": true,
          "sources": [
            {
              "req_id": "REQ-CIP-01",
              "source": "reg:31CFR1020.220(a)(2)(i)@2026-01",
              "owner": "BSA Officer",
              "status": "approved"
            }
          ]
        },
        {
          "clause_id": "C-4",
          "heading": "Identity verification",
          "text": "The bank shall verify each customer's identity within a reasonable time after account opening using documentary or non-documentary methods.",
          "normative": true,
          "sources": [
            {
              "req_id": "REQ-CIP-02",
              "source": "reg:31CFR1020.220(a)(2)(ii)@2026-01",
              "owner": "BSA Officer",
              "status": "approved"
            }
          ]
        },
        {
          "clause_id": "C-5",
          "heading": "Recordkeeping",
          "text": "Customer identification records shall be retained for five years after the account is closed.",
          "normative": true,
          "sources": [
            {
              "req_id": "REQ-CIP-03",
              "source": "reg:31CFR1020.220(a)(3)@2026-01",
              "owner": "Records Manager",
              "status": "approved"
            }
          ]
        },
        {
          "clause_id": "C-6",
          "heading": "High-risk customers",
          "text": "Enhanced due diligence shall be applied to customers rated high risk under the enterprise risk model.",
          "normative": true,
          "sources": [
            {
              "req_id": "REQ-INT-07",
              "source": "policy:ERM-STD-04@v3.1",
              "owner": "Chief Risk Officer",
              "status": "approved"
            }
          ]
        }
      ]
    },
    {
      "section_id": "exceptions-escalation",
      "heading": "Exceptions and Escalation",
      "clauses": [
        {
          "clause_id": "C-8",
          "heading": "Exceptions",
          "text": "Exceptions to this policy must be approved in writing by the BSA Officer and logged in the exception register.",
          "normative": false
        }
      ]
    },
    {
      "section_id": "roles-responsibilities",
      "heading": "Roles and Responsibilities",
      "clauses": [
        {
          "clause_id": "C-7",
          "heading": "Roles and responsibilities",
          "text": "The BSA Officer owns this policy. Line-of-business managers are responsible for operational execution.",
          "normative": false
        }
      ]
    },
